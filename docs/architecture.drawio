<mxfile host="app.diagrams.net">
  <diagram name="architecture" id="arch1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="vnet" value="VNet (VNet DNS → Resolver Inbound)" style="rounded=1;dashed=1;container=1;pointerEvents=0;fillColor=#F0F6FF;strokeColor=#6C8EBF;fontColor=#1F3A5F;fontSize=13;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="860" height="560" as="geometry" />
        </mxCell>

        <mxCell id="vm" value="Test VM" style="image;aspect=fixed;image=img/lib/azure2/compute/Virtual_Machine.svg;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="vnet">
          <mxGeometry x="40" y="220" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="inb" value="Resolver Inbound&#10;Endpoint" style="image;aspect=fixed;image=img/lib/azure2/networking/DNS_Private_Resolver.svg;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="vnet">
          <mxGeometry x="220" y="220" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ruleset" value="Forwarding Ruleset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CE;strokeColor=#D79B00;fontSize=12;" vertex="1" parent="vnet">
          <mxGeometry x="370" y="140" width="220" height="220" as="geometry" />
        </mxCell>

        <mxCell id="bypass" value="Microsoft zones&#10;(implicit bypass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="ruleset">
          <mxGeometry x="15" y="30" width="190" height="55" as="geometry" />
        </mxCell>

        <mxCell id="wild" value="Wildcard &quot;.&quot; rule&#10;→ unreachable RFC1918 IPs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="ruleset">
          <mxGeometry x="15" y="120" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="outb" value="Resolver Outbound&#10;Endpoint" style="image;aspect=fixed;image=img/lib/azure2/networking/DNS_Private_Resolver.svg;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="vnet">
          <mxGeometry x="670" y="220" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="afw" value="Azure Firewall Premium" style="image;aspect=fixed;image=img/lib/azure2/networking/Firewalls.svg;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="vnet">
          <mxGeometry x="390" y="440" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="azdns" value="Azure DNS&#10;168.63.129.16" style="image;aspect=fixed;image=img/lib/azure2/networking/DNS_Zones.svg;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="1080" y="180" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="bh" value="Blackhole&#10;(unreachable IPs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="400" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="mgmt" value="AFW management&#10;control plane" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1050" y="540" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="DNS query" style="edgeStyle=orthogonalEdgeStyle;rounded=1;labelBackgroundColor=#FFFFFF;fontSize=11;" edge="1" parent="vnet" source="vm" target="inb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="vnet" source="inb" target="ruleset">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e3" value="resolves" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;labelBackgroundColor=#FFFFFF;fontSize=11;" edge="1" parent="1" source="bypass" target="azdns">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="forwards" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;labelBackgroundColor=#FFFFFF;fontSize=11;" edge="1" parent="vnet" source="wild" target="outb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" value="timeout" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;dashed=1;labelBackgroundColor=#FFFFFF;fontSize=11;" edge="1" parent="1" source="outb" target="bh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6" value="provisions OK (platform path)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673A6;labelBackgroundColor=#FFFFFF;fontSize=11;" edge="1" parent="1" source="afw" target="mgmt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Green = resolves&#10;Red dashed = blackholed / timeout&#10;Purple = platform control-plane (unaffected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="680" width="360" height="70" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
